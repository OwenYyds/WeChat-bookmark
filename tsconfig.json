{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2020"],
    "types": ["miniprogram-api-typings"],
    "skipLibCheck": true
  },
  "include": ["miniprogram/**/*.ts", "miniprogram/**/*.d.ts"]
}
