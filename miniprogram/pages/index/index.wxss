.page {
  padding: 24rpx;
}

.summary {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 600;
}

.month-picker {
  margin-top: 16rpx;
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  font-size: 24rpx;
}

.summary-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.label {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.value {
  display: block;
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.income {
  color: #0f766e;
}

.expense {
  color: #b91c1c;
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.add-btn {
  margin: 0;
  padding: 0 20rpx;
  line-height: 56rpx;
}

.empty {
  padding: 30rpx;
  color: #64748b;
  text-align: center;
}

.item {
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.category {
  font-size: 30rpx;
  font-weight: 600;
}

.amount {
  font-size: 32rpx;
  font-weight: 700;
}

.item-middle {
  margin-top: 10rpx;
  color: #475569;
  font-size: 24rpx;
}

.item-bottom {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  color: #64748b;
  font-size: 22rpx;
}

.actions {
  display: flex;
  gap: 24rpx;
}

.danger {
  color: #dc2626;
}
