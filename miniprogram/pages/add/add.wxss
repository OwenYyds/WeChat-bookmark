.page {
  padding: 24rpx;
}

.form-card {
  padding: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #334155;
  font-size: 24rpx;
}

.type-row {
  display: flex;
  gap: 40rpx;
}

.type-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
}

.input,
.picker,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 14rpx 18rpx;
  font-size: 28rpx;
}

.textarea {
  height: 160rpx;
}

.submit {
  margin-top: 24rpx;
}
